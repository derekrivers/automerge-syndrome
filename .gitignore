# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle
/vendor/bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
!/tmp/storage
!/tmp/cache
!/tmp/pids/.keep
!/tmp/storage/.keep
!/tmp/cache/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore local environment files.
.env
.env.*
!.env.example

# Ignore Rails credentials and local database artifacts.
/config/master.key
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore asset build output except committed placeholders and baseline CSS.
/app/assets/builds/*
!/app/assets/builds/.keep
!/app/assets/builds/tailwind.css

# Ignore JavaScript dependencies if introduced later.
/node_modules

# Ignore editor and OS metadata.
.DS_Store
.vscode/
.idea/
